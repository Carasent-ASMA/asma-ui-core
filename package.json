{
    "name": "asma-ui-core",
    "publishConfig": {
        "access": "public"
    },
    "version": "0.0.1",
    "type": "module",
    "files": [
        "dist/**/*",
        "dist/style.css",
        "tw-configs/**/*"
    ],
    "keywords": [],
    "author": "asma-team",
    "types": "./dist/index.d.ts",
    "main": "./dist/asma-ui-core.es.js",
    "module": "./dist/asma-ui-core.es.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/asma-ui-core.es.js"
            }
        },
        "./dist/style.css": "./dist/style.css",
        "./tw-configs/twConfigs.json": "./tw-configs/twConfigs.json"
    },
    "scripts": {
        "dev": "vite",
        "build": "pnpm exec tsc && rm -rf ./dist && vite build",
        "preview": "vite preview",
        "lint": "eslint src .storybook",
        "version": "echo $npm_package_version",
        "lint:fix": "eslint --fix src .storybook",
        "prettier": "prettier --write src//**/*.{ts,tsx,scss} --config ./.prettierrc",
        "storybook": "storybook dev -p 6006",
        "storybook:no-browser": "storybook dev -p 6006 --no-open",
        "storybook:node18": "export NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "storybook:node18:win": "set NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "build-storybook": "export NODE_OPTIONS=--max_old_space_size=6240 && storybook build",
        "test-storybook": "test-storybook",
        "changeset:pre-beta": "changeset pre enter beta",
        "changeset:pre-exit": "changeset pre exit",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "changeset:status": "changeset status"
    },
    "license": "UNLICENSED",
    "engines": {
        "node": ">=24 <25"
    },
    "dependencies": {
        "@base-ui-components/react": "1.0.0-rc.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/material-icons": "^5.2.7",
        "@iconify/react": "^6.0.2",
        "@mui/material": "^7.3.9",
        "@tanstack/react-table": "^8.21.3",
        "asma-ui-icons": "^0.3.3",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lodash-es": "^4.17.23",
        "material-ui-popup-state": "^5.3.6",
        "notistack": "^3.0.2",
        "react-day-picker": "^9.14.0",
        "react-quill": "^2.0.0",
        "sass": "^1.98.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@faker-js/faker": "^10.4.0",
        "@rollup/plugin-terser": "^1.0.0",
        "@storybook/addon-a11y": "^10.3.3",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/addon-interactions": "^8.6.14",
        "@storybook/addon-links": "^10.3.3",
        "@storybook/addon-mdx-gfm": "^8.6.14",
        "@storybook/addon-themes": "^10.3.3",
        "@storybook/blocks": "^8.6.14",
        "@storybook/manager-api": "^8.6.14",
        "@storybook/react-vite": "^10.3.3",
        "@storybook/test-runner": "^0.24.3",
        "@storybook/theming": "^8.6.14",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.4.27",
        "axe-playwright": "^2.2.2",
        "axios": "^1.13.6",
        "eslint": "^10.1.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-storybook": "^10.3.3",
        "globals": "^17.4.0",
        "node": "24.14.1",
        "postcss": "^8.5.8",
        "prop-types": "^15.8.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "rollup-plugin-typescript2": "^0.36.0",
        "storybook": "^10.3.3",
        "tailwind-merge": "^2.6.1",
        "tailwind-scrollbar": "^3.1.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.2",
        "typescript-plugin-css-modules": "^5.2.0",
        "vite": "^8.0.2",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "@emotion/react": "^11.*",
        "@emotion/styled": "^11.*",
        "@mui/material": "^7.3.9",
        "immer": "^11.1.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Carasent-ASMA/asma-ui-core.git"
    },
    "resolutions": {
        "@types/node": "25.5.0",
        "node": "24.14.1"
    }
}
