{
    "name": "asma-core-ui",
    "publishConfig": {
        "access": "public"
    },
    "version": "3.2.21",
    "type": "module",
    "files": [
        "dist/**/*",
        "dist/style.css",
        "tw-configs/**/*"
    ],
    "keywords": [],
    "author": "asma-team",
    "types": "./dist/index.d.ts",
    "main": "./dist/asma-core-ui.es.js",
    "module": "./dist/asma-core-ui.es.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/asma-core-ui.es.js"
            }
        },
        "./dist/style.css": "./dist/style.css",
        "./tw-configs/twConfigs.json": "./tw-configs/twConfigs.json"
    },
    "scripts": {
        "dev": "vite",
        "build": "npx tsc && rm -rf ./dist && vite build",
        "preview": "vite preview",
        "lint": "eslint src/**/*.{ts,tsx} --cache",
        "version": "echo $npm_package_version",
        "lint:fix": "eslint --fix src/**/*.{ts,tsx}",
        "prettier": "prettier --write src//**/*.{ts,tsx,scss} --config ./.prettierrc",
        "return:types": "tsx scripts/add-missing-return-types.ts",
        "storybook": "storybook dev -p 6006",
        "storybook:no-browser": "storybook dev -p 6006 --no-open",
        "build-storybook": "export NODE_OPTIONS=--max_old_space_size=6240 && storybook build",
        "test-storybook": "npx vitest --project=storybook",
        "changeset:pre-beta": "changeset pre enter beta",
        "changeset:pre-exit": "changeset pre exit",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "changeset:status": "changeset status"
    },
    "license": "UNLICENSED",
    "dependencies": {
        "@base-ui/react": "^1.0.0",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@iconify/react": "^4.1.1",
        "@mui/material": "^5.18.0",
        "@tanstack/react-table": "^8.10.0",
        "asma-ui-icons": "^0.0.35",
        "clsx": "^1.2.1",
        "date-fns": "^2.30.0",
        "lodash-es": "^4.17.21",
        "material-ui-popup-state": "^5.0.10",
        "notistack": "^3.0.2",
        "react-day-picker": "^8.8.2",
        "react-quill": "^2.0.0",
        "sass": "^1.77.5"
    },
    "devDependencies": {
        "@changesets/cli": "^2.26.2",
        "@chromatic-com/storybook": "^5.0.0",
        "@eslint/js": "^9.39.2",
        "@faker-js/faker": "^8.0.2",
        "@joshwooding/vite-plugin-react-docgen-typescript": "^0.6.3",
        "@rollup/plugin-terser": "^0.4.3",
        "@storybook/addon-a11y": "10.2.4",
        "@storybook/addon-docs": "10.2.4",
        "@storybook/addon-links": "10.2.4",
        "@storybook/addon-themes": "^10.2.4",
        "@storybook/addon-vitest": "10.2.4",
        "@storybook/preset-create-react-app": "10.2.4",
        "@storybook/react-vite": "10.2.4",
        "@storybook/test-runner": "^0.24.2",
        "@types/lodash-es": "^4.17.7",
        "@types/node": "^18.0.3",
        "@types/react": "^18.0.37",
        "@types/react-dom": "^18.0.11",
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "@vitejs/plugin-react": "^4.0.0",
        "@vitest/browser-playwright": "^4.0.16",
        "@vitest/coverage-v8": "^4.0.16",
        "autoprefixer": "^10.4.14",
        "axe-playwright": "^1.2.3",
        "axios": "^1.6.8",
        "chromatic": "^13.3.4",
        "eslint": "^9.39.2",
        "eslint-plugin-better-tailwindcss": "^3.8.0",
        "eslint-plugin-de-morgan": "^2.0.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.3.4",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.7.0",
        "eslint-plugin-regexp": "^2.10.0",
        "eslint-plugin-sonarjs": "^3.0.5",
        "eslint-plugin-storybook": "10.2.4",
        "node": "18.17.0",
        "playwright": "^1.57.0",
        "postcss": "^8.4.24",
        "prop-types": "^15.8.1",
