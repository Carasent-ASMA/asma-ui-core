        "react-dom": "^18.2.0",
        "rollup-plugin-typescript2": "^0.35.0",
        "storybook": "10.2.4",
        "tailwind-merge": "^2.4.0",
        "tailwind-scrollbar": "^3.1.0",
        "tailwindcss": "^3.3.2",
        "ts-morph": "^27.0.2",
        "tsx": "^4.21.0",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.50.0",
        "typescript-plugin-css-modules": "^5.0.1",
        "vite": "^7.3.0",
        "vite-plugin-dts": "^4.5.4",
        "vite-tsconfig-paths": "^4.2.0",
        "vitest": "^4.0.16"
    },
    "peerDependencies": {
        "@emotion/react": "^11.*",
        "@emotion/styled": "^11.*",
        "@mui/material": "^5.*",
        "immer": "^9.*",
        "react": "^18.*",
        "react-dom": "^18.*"
    },
    "resolutions": {
        "@types/node": "18.0.3",
        "node": "18.17.0"
    }
}
