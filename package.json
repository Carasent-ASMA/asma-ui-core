{
    "name": "asma-ui-core",
    "publishConfig": {
        "access": "public"
    },
    "version": "0.0.1",
    "type": "module",
    "files": [
        "dist/**/*",
        "dist/style.css",
        "tw-configs/**/*"
    ],
    "keywords": [],
    "author": "asma-team",
    "types": "./dist/index.d.ts",
    "main": "./dist/asma-ui-core.es.js",
    "module": "./dist/asma-ui-core.es.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/asma-ui-core.es.js",
            "default": "./dist/asma-ui-core.es.js"
        },
        "./dist/style.css": "./dist/style.css",
        "./tw-configs/twConfigs.json": "./tw-configs/twConfigs.json"
    },
    "scripts": {
        "chromatic": "npx chromatic --config-file chromatic.config.json",
        "dev": "vite",
        "build": "pnpm exec tsc && rm -rf ./dist && vite build",
        "preview": "vite preview",
        "lint": "eslint src/**/*.{ts,tsx} --cache",
        "version": "echo $npm_package_version",
        "lint:fix": "eslint --fix src/**/*.{ts,tsx}",
        "return:types": "tsx scripts/add-missing-return-types.ts",
        "storybook": "storybook dev -p 6006",
        "storybook:no-browser": "storybook dev -p 6006 --no-open",
        "build-storybook": "export NODE_OPTIONS=--max_old_space_size=6240 && storybook build",
        "test-storybook": "npx vitest --project=storybook",
        "changeset:pre-beta": "changeset pre enter beta",
        "changeset:pre-exit": "changeset pre exit",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "changeset:status": "changeset status"
    },
    "license": "UNLICENSED",
    "engines": {
        "node": ">=24 <25"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@iconify/react": "^4.1.1",
        "@mui/material": "^5.18.0",
        "asma-ui-icons": "^0.0.35",
        "clsx": "^1.2.1",
        "lodash-es": "^4.17.21",
        "sass": "^1.98.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.26.2",
        "@chromatic-com/storybook": "^5.1.1",
        "@eslint/js": "^9.39.2",
        "@storybook/addon-a11y": "10.3.3",
        "@storybook/addon-docs": "10.3.3",
        "@storybook/addon-links": "10.3.3",
        "@storybook/addon-themes": "^10.3.3",
        "@storybook/addon-vitest": "10.3.3",
        "@storybook/react-vite": "10.3.3",
        "@storybook/test-runner": "^0.24.3",
        "@types/lodash-es": "^4.17.7",
        "@types/node": "^18.0.3",
        "@types/react": "^18.0.37",
        "@types/react-dom": "^18.0.11",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.0.16",
        "autoprefixer": "^10.4.27",
        "axe-playwright": "^1.2.3",
        "chromatic": "^13.3.4",
        "eslint": "^9.39.2",
        "eslint-plugin-better-tailwindcss": "^3.8.0",
        "eslint-plugin-de-morgan": "^2.0.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.7.0",
        "eslint-plugin-regexp": "^2.10.0",
        "eslint-plugin-storybook": "10.3.3",
        "notistack": "^3.0.2",
        "playwright": "^1.57.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "storybook": "10.3.3",
        "storybook-addon-pseudo-states": "^10.3.3",
        "tailwind-merge": "^2.4.0",
        "tailwind-scrollbar": "^3.1.0",
        "tailwindcss": "^3.3.2",
        "ts-morph": "^27.0.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.50.0",
        "typescript-plugin-css-modules": "^5.0.1",
        "vite": "^8.0.3",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.16"
    },
    "peerDependencies": {
        "@emotion/react": "^11.*",
        "@emotion/styled": "^11.*",
        "@mui/material": "^5.*",
        "immer": "^9.*",
        "react": "^18.*",
        "react-dom": "^18.*"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Carasent-ASMA/asma-ui-core.git"
    },
    "resolutions": {
        "@types/node": "25.5.0",
        "node": "24.14.1"
    }
}
