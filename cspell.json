{
    // Version of the setting file.  Always 0.2
    "version": "0.2",
    // language - current active spelling language
    "language": "en, nb, nb-NO",
    // words - list of words to be always considered correct
    "words": [
        "asma",
        "autodocs",
        "clsx",
        "Docgen",
        "fontsource",
        "Fretex",
        "iconify",
        "keyframes",
        "mertasan",
        "notistack",
        "Roboto",
        "tailwindcss"
    ],
    "ignorePaths": [
        "package-lock.json",
        "node_modules",
        "vscode-extension",
        ".git/objects",
        ".vscode",
        ".vscode-insiders",
        "cspell.json",
        "dist",
        "yarn*",
        "*norwegian_postal_codes*",
        "target/npmlist.json",
        "img",
        "*.backup",
        //TODO this is temporary shall be removed when all misspellings are fixed in .scss files
        "*.scss",
        //TODO this is temporary as well need to fix all misspellings
        "tailwind.config.js"
    ],
    "import": [
        "@cspell/dict-nb-no/cspell-ext.json"
    ],
    "ignoreRegExpList": [
        "enum.*"
    ]
    // flagWords - list of words to be always considered incorrect
    // This is useful for offensive words and common spelling errors.
    // For example "hte" should be "the"
}
